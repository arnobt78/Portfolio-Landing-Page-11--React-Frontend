# Frontend (Vite)
# Get these from your Mailchimp audience embedded form URL.
VITE_MAILCHIMP_URL=your-mailchimp-url
VITE_MAILCHIMP_U=your-mailchimp-u
VITE_MAILCHIMP_ID=your-mailchimp-id

# Backend (Express + Nodemailer)
# Use a Gmail address and a Google App Password (not your normal Gmail password).
EMAIL_USER=your-email-user
EMAIL_PASS=your-email-pass
# Optional: where contact form emails should be sent.
EMAIL_TO=your-email-to

# Optional backend port (frontend currently posts to http://localhost:5000/contact)
PORT=5000
